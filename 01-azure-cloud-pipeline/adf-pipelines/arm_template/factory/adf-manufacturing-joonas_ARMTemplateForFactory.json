{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "adf-manufacturing-joonas"
        },
        "dataFactory_location": {
            "type": "string",
            "defaultValue": "swedencentral"
        },
        "dataFactory_identity_type": {
            "type": "string",
            "defaultValue": "SystemAssigned"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "[parameters('factoryName')]",
            "type": "Microsoft.DataFactory/factories",
            "apiVersion": "2018-06-01",
            "properties": {
                "trustModeClaimForMi": {
                    "value": "Disabled",
                    "editable": true
                }
            },
            "dependsOn": [],
            "location": "[parameters('dataFactory_location')]",
            "identity": {
                "type": "[parameters('dataFactory_identity_type')]",
                "principalId": "bc108ad1-6299-431d-b939-7f2e814ecaab",
                "tenantId": "41652b87-445a-4388-b28d-9ebb2e66ae5e"
            }
        }
    ]
}