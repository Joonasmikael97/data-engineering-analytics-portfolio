                            },
                            "traceLevel": "Fine"
                        }
                    }
                ],
                "policy": {
                    "elapsedTimeMetric": {}
                },
                "annotations": [],
                "lastPublishTime": "2026-07-22T16:46:24Z"
            },
            "dependsOn": [
                "[concat(variables('factoryId'), '/linkedServices/AzureSqlDatabase1')]",
                "[concat(variables('factoryId'), '/dataflows/DF_Clean_Maintenance')]",
                "[concat(variables('factoryId'), '/dataflows/DF_Clean_Production')]",
                "[concat(variables('factoryId'), '/dataflows/DF_Clean_Quality')]"
